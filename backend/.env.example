# HealthGuide AI — Environment Variables Template
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=health_guide
DB_USER=root
DB_PASS=your_password_here

# JWT - Generate a strong random secret (e.g., use: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# OpenRouter API (free at https://openrouter.ai)
# Get your free API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here
